{
    "mcpServers": {
        "gemini-design-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "gemini-design-mcp@latest"
            ],
            "env": {
                "API_KEY": "YOUR_API_KEY_HERE"
            }
        },
        "magic": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@21st-dev/magic@latest"
            ],
            "env": {
                "API_KEY": "YOUR_API_KEY_HERE"
            }
        }
    }
}
